{
  "name": "mcp-gcal-journal",
  "version": "1.0.0",
  "description": "MCP server for Google Calendar — a structured diary journal with auto-classification",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-gcal-journal": "./dist/index.js",
    "gcj-auth": "./dist/auth/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "auth": "node dist/auth/cli.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "google-calendar",
    "model-context-protocol"
  ],
  "author": "Fahim",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ajv": "^8.20.0",
    "googleapis": "^144.0.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
